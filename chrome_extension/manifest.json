{
  "manifest_version": 3,
  "name": "Winbridge Chrome Bridge",
  "version": "0.1.3",
  "description": "Expose active tab DOM state and execute simple commands via Winbridge.",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:5100/*", "http://localhost:5100/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
